// TimeWizard - Prisma Schema
// Dokumentacja: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH (NextAuth.js) ====================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Token do resetowania hasła
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, token])
  @@map("password_reset_tokens")
}

// Token do weryfikacji email
model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, token])
  @@map("email_verification_tokens")
}

// ==================== USERS ====================
// Plan: FREE, PRO, BUSINESS (stored as String for SQLite)

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  timezone      String    @default("Europe/Warsaw")
  plan          String    @default("FREE") // FREE, PRO, BUSINESS
  
  // Stripe
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  stripePriceId          String?   @map("stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map("stripe_current_period_end")
  
  // Gamification
  streakCount         Int       @default(0) @map("streak_count")
  lastActiveAt        DateTime? @map("last_active_at")
  totalTasksCompleted Int       @default(0) @map("total_tasks_completed")
  xp                  Int       @default(0) // Experience points
  level               Int       @default(1) // User level
  
  // Onboarding
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  onboardingStep      Int       @default(0) @map("onboarding_step")
  userGoal            String?   @map("user_goal") // WORK, STUDIES, PROJECTS, PERSONAL
  firstLoginAt        DateTime? @map("first_login_at")
  tooltipsShown       String?   @map("tooltips_shown") // JSON array of shown tooltip IDs
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  accounts           Account[]
  sessions           Session[]
  categories         Category[]
  tasks              Task[]
  availabilityBlocks AvailabilityBlock[]
  scheduledTasks     ScheduledTask[]
  achievements       UserAchievement[]
  pomodoroSessions   PomodoroSession[]
  timeEntries        TimeEntry[]

  @@map("users")
}

// ==================== CATEGORIES ====================

model Category {
  id     String  @id @default(cuid())
  userId String  @map("user_id")
  name   String
  color  String  @default("#4F46E5")
  icon   String?
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@unique([userId, name])
  @@map("categories")
}

// ==================== TASKS ====================
// TaskStatus: PENDING, IN_PROGRESS, COMPLETED, CANCELLED
// RecurringType: DAILY, WEEKLY, MONTHLY

model Task {
  id          String  @id @default(cuid())
  userId      String  @map("user_id")
  categoryId  String? @map("category_id")
  
  title            String
  description      String?
  priority         Int     @default(1) // 1-5
  estimatedMinutes Int     @map("estimated_minutes")
  dueDate          DateTime? @map("due_date")
  
  // Recurring
  isRecurring      Boolean @default(false) @map("is_recurring")
  recurringType    String? @map("recurring_type") // DAILY, WEEKLY, MONTHLY
  recurringDays    String? @map("recurring_days") // JSON string: [0,1,2,3,4,5,6]
  recurringEndDate DateTime? @map("recurring_end_date")
  
  // Status
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  completedAt DateTime? @map("completed_at")
  
  // Metadata
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  // Relations
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  scheduledTasks ScheduledTask[]
  subtasks       Subtask[]
  pomodoroSessions PomodoroSession[]
  timeEntries    TimeEntry[]

  @@index([userId, status])
  @@index([userId, dueDate])
  @@map("tasks")
}

// ==================== SUBTASKS ====================

model Subtask {
  id        String  @id @default(cuid())
  taskId    String  @map("task_id")
  title     String
  completed Boolean @default(false)
  order     Int     @default(0)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, order])
  @@map("subtasks")
}

// ==================== TASK TEMPLATES ====================

model TaskTemplate {
  id               String  @id @default(cuid())
  userId           String  @map("user_id")
  name             String
  title            String
  description      String?
  priority         Int     @default(1)
  estimatedMinutes Int     @map("estimated_minutes")
  categoryId       String? @map("category_id")
  subtasks         String? // JSON array of subtask titles
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("task_templates")
}

// ==================== AVAILABILITY ====================
// BlockType: WORK, PERSONAL, FOCUS

model AvailabilityBlock {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  dayOfWeek Int    @map("day_of_week") // 0 = Sunday, 6 = Saturday
  startTime String @map("start_time")  // "09:00"
  endTime   String @map("end_time")    // "17:00"
  blockType String @default("WORK") @map("block_type") // WORK, PERSONAL, FOCUS
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime])
  @@map("availability_blocks")
}

// ==================== SCHEDULE ====================

model ScheduledTask {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  taskId         String   @map("task_id")
  scheduledStart DateTime @map("scheduled_start")
  scheduledEnd   DateTime @map("scheduled_end")
  isLocked       Boolean  @default(false) @map("is_locked")
  
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledStart])
  @@map("scheduled_tasks")
}

// ==================== GAMIFICATION ====================

model Achievement {
  id          String @id @default(cuid())
  code        String @unique // "first_week", "perfectionist", etc.
  name        String
  description String
  icon        String
  
  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

// ==================== POMODORO ====================

model PomodoroSession {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  taskId      String?   @map("task_id")
  
  duration    Int       @default(25) // Duration in minutes
  type        String    @default("WORK") // WORK, SHORT_BREAK, LONG_BREAK
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  completed   Boolean   @default(false)
  
  createdAt   DateTime  @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@map("pomodoro_sessions")
}

// ==================== TIME TRACKING ====================

model TimeEntry {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  taskId    String    @map("task_id")
  
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  duration  Int?      // Duration in seconds (calculated on end)
  note      String?
  
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([taskId])
  @@map("time_entries")
}

// ==================== PLAN LIMITS ====================

model PlanLimit {
  plan          String @id // FREE, PRO, BUSINESS
  maxTasks      Int    @map("max_tasks")
  maxCategories Int    @map("max_categories")
  historyDays   Int    @map("history_days")
  features      String // JSON string

  @@map("plan_limits")
}
